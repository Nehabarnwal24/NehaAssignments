@model IEnumerable<MVCExampledemo.Models.Employee>
@{
    ViewData["Title"] = "EmpsInDept";
}

<h1>EmpsInDept</h1>

<table border="1" cellpadding="2" cellspacing="3">
    <tr>
        <th>EmployeeID</th>
        <th>EmpName</th>
        <th>EmpSalary</th>
        <th>Image</th>
    </tr>
@foreach (var emp in Model)

    {
        <tr>
            <td>@emp.EmployeeId</td>
            <td>@emp.EmpName</td>
            <td>@emp.Salary</td>
            <td>
                <img src="@emp.ImageUrl" width="100" height="100"/>
            </td>
            <td>
                <a href="/Home/Details?id=@emp.EmployeeId">Details</a>
            </td>
        </tr>
}
</table>